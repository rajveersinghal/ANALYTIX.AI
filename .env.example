# AnalytixAI Environment Configuration Template

# App Info
APP_NAME=AnalytixAI
DEBUG=True

# MongoDB Connection
# Use Local for development to avoid IP Whitelist and SSL issues.
# Use Atlas for production.
# Local Example: mongodb://localhost:27017/analytixai
# Atlas Example: mongodb+srv://<user>:<pass>@cluster0.xz2us4c.mongodb.net/?appName=Cluster0
MONGODB_URL=mongodb://localhost:27017/analytixai
DATABASE_NAME=analytixai

# Security
JWT_SECRET=your-256-bit-secret-here

# AI Engine
GENAI_API_KEY=your-gemini-api-key-here

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
