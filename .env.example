# AnalytixAI Environment Configuration Template

# App Info
APP_NAME=AnalytixAI
DEBUG=True

# Deployment / Frontend
# VITE_API_URL: Your backend URL (if deploying backend separately) or leave blank if using the monorepo config.
VITE_API_URL=

# MongoDB Connection
# Use Atlas for production.
# Atlas Example: mongodb+srv://<user>:<pass>@cluster0.xz2us4c.mongodb.net/?appName=Cluster0
MONGODB_URL=mongodb+srv://<user>:<pass>@cluster0.abcde.mongodb.net/analytix_db
DATABASE_NAME=analytix_db

# Security
JWT_SECRET=your-random-jwt-secret-here

# AI Engine
GEMINI_API_KEY=your-gemini-api-key-here
GENAI_API_KEY=your-gemini-api-key-here

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
